# -------- InfluxDB Configuration --------
# Admin credentials (used for initial setup)
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=changeme_influxdb_admin_password

# Organization and storage settings
INFLUXDB_ORG=my-org
INFLUXDB_BUCKET=iot_data

# Admin API token (for service authentication)
# Generate a strong token before deploying to production
INFLUXDB_TOKEN=change-me-to-a-strong-secret-token-at-least-32-chars

# -------- Analytics Service Configuration --------
HTTP_ADDR=:3000
INFLUX_MEASUREMENT=mpu6050